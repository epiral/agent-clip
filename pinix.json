{
  "name": "agent",
  "version": "0.3.0",
  "type": "clip",
  "description": "AI Agent — agentic loop with shell, packages, and memory",
  "domain": "ai",
  "runtime": "bun",
  "main": "index.ts",
  "web": "web/",
  "commands": [
    { "name": "send", "description": "发送消息并执行 agentic loop" },
    { "name": "create-topic", "description": "创建新话题" },
